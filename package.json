{
    "name": "stitchflow-ai",
    "version": "1.0.0",
    "description": "StitchFlow AI – Monorepo (Frontend + Backend)",
    "private": true,
    "workspaces": [
        "frontend",
        "backend"
    ],
    "scripts": {
        "dev:frontend": "cd frontend && npm run dev",
        "dev:backend": "cd backend  && npm run dev",
        "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}